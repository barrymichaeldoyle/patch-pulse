{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["ngrok"],
  "ignoreIssues": {
    "packages/notifier-bot/src/services/supabase/gen/**": ["types"]
  },
  "workspaces": {
    "packages/cli": {
      "entry": ["scripts/*.cjs"],
      "project": ["src/**/*.ts", "scripts/*.cjs"]
    },
    "packages/notifier-bot": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["ts-loader"]
    },
    "packages/vscode-extension": {
      "entry": ["src/extension.ts", "src/test/**/*.ts", ".vscode-test.mjs"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@vscode/test-electron"]
    }
  }
}
