{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/cli": {
      "entry": ["scripts/*.cjs"],
      "project": ["src/**/*.ts", "scripts/*.cjs"]
    },
    "packages/notifier-bot": {
      "entry": ["convex/http.ts", "convex/crons.ts"],
      "project": ["convex/**/*.ts", "!convex/_generated/**"]
    },
    "packages/vscode-extension": {
      "entry": ["src/extension.ts", "src/test/**/*.ts", ".vscode-test.mjs"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@vscode/test-electron"]
    }
  }
}
