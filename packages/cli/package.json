{
  "name": "patch-pulse",
  "version": "4.1.1",
  "description": "Check for outdated npm dependencies",
  "type": "module",
  "bin": {
    "patch-pulse": "lib/index.js"
  },
  "files": [
    "lib/index.js",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "keywords": [
    "cli",
    "npm",
    "dependencies",
    "package.json",
    "updates",
    "version-check",
    "patch-pulse"
  ],
  "license": "MIT",
  "author": {
    "name": "Barry Michael Doyle",
    "email": "barry@barrymichaeldoyle.com"
  },
  "homepage": "https://barrymichaeldoyle.github.io/patch-pulse/",
  "bugs": {
    "url": "https://github.com/barrymichaeldoyle/patch-pulse/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barrymichaeldoyle/patch-pulse.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node scripts/generate-version.cjs && node scripts/build.cjs",
    "dev": "tsx src/index.ts",
    "test:build": "npm run build && node lib/index.js",
    "test:version": "npm run build && node lib/index.js --version",
    "test:help": "npm run build && node lib/index.js --help",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@patch-pulse/shared": "workspace:*"
  }
}
