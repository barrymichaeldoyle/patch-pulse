{
  "name": "patch-pulse-vscode-extension",
  "displayName": "Patch Pulse",
  "description": "Keep a pulse on npm package updates! Shows inline version information for packages in package.json files.",
  "version": "0.0.1",
  "private": true,
  "author": {
    "name": "Barry Michael Doyle",
    "email": "barry@barrymichaeldoyle.com"
  },
  "publisher": "patch-pulse",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.2"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:json",
    "workspaceContains:**/package.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "iconThemes": [
      {
        "id": "patch-pulse-icons",
        "label": "Patch Pulse Icons",
        "path": "./icons/patchpulse-icon-theme.json"
      }
    ],
    "commands": [
      {
        "command": "patch-pulse.checkVersions",
        "title": "Patch Pulse: Check Package Versions",
        "category": "Patch Pulse"
      },
      {
        "command": "patch-pulse.refreshVersions",
        "title": "Patch Pulse: Refresh Package Versions",
        "category": "Patch Pulse"
      }
    ],
    "configuration": {
      "title": "Patch Pulse",
      "properties": {
        "patchPulse.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Patch Pulse functionality"
        },
        "patchPulse.checkOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Check versions when package.json files are opened"
        },
        "patchPulse.updateInterval": {
          "type": "number",
          "default": 3600,
          "description": "Update interval in seconds (default: 1 hour)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "1.115.0",
    "npm-run-all": "4.1.5",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@patch-pulse/shared": "workspace:*"
  }
}
