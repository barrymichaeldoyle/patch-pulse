---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a class="discord-button" href={href}>
  <span class="discord-button__label">Add to Discord</span>
</a>

<style>
  .discord-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1.1rem;
    margin: 1rem 0 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      linear-gradient(180deg, #6a75f7 0%, #5865f2 100%);
    box-shadow:
      0 12px 28px rgba(88, 101, 242, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      filter 160ms ease;
  }

  .discord-button:hover {
    transform: translateY(-1px);
    box-shadow:
      0 16px 36px rgba(88, 101, 242, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    filter: brightness(1.03);
  }

  .discord-button:focus-visible {
    outline: 2px solid #e0e3ff;
    outline-offset: 3px;
  }

  .discord-button__label {
    white-space: nowrap;
  }
</style>
